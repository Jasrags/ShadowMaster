    "autosoft-types": {
      "source": "SR5 Core Rulebook, p. 269–270",
      "description": "Autosoft program types available for drones and their skill equivalents",
      "columns": ["name", "model_specific", "skill_equivalent", "notes"],
      "rows": [
        {
          "name": "Clearsight",
          "model_specific": false,
          "skill_equivalent": "Perception",
          "notes": "Acts as the drone's Perception skill"
        },
        {
          "name": "Electronic Warfare",
          "model_specific": false,
          "skill_equivalent": "Electronic Warfare",
          "notes": "Exactly like the Electronic Warfare skill"
        },
        {
          "name": "[Model] Evasion",
          "model_specific": true,
          "skill_equivalent": null,
          "notes": "Teaches drone autopilot to avoid being locked onto by Sensors"
        },
        {
          "name": "[Model] Maneuvering",
          "model_specific": true,
          "skill_equivalent": "Pilot [Vehicle type]",
          "notes": "Pilot Vehicle-type skill for one specific drone model only"
        },
        {
          "name": "[Model] Stealth",
          "model_specific": true,
          "skill_equivalent": "Infiltration",
          "notes": "Helps drone operate with stealth; acts as Infiltration skill for that drone model"
        },
        {
          "name": "[Weapon] Targeting",
          "model_specific": true,
          "skill_equivalent": "Gunnery",
          "notes": "Gunnery skill for one specific mounted weapon model (e.g., Ingram Smartgun Targeting)"
        }
      ]
    },
    "rigger-cyberprograms": {
      "source": "SR5 Core Rulebook, p. 269",
      "description": "Cyberprograms available for RCCs (not compatible with cyberdecks). RCC cannot run more than one program of the same type.",
      "columns": ["program", "effect"],
      "rows": [
        {
          "program": "Encryption",
          "effect": "+1 Firewall"
        },
        {
          "program": "Signal Scrub",
          "effect": "Rating 2 noise reduction"
        },
        {
          "program": "Toolbox",
          "effect": "+1 Data Processing"
        },
        {
          "program": "Virtual Machine",
          "effect": "2 extra program slots; take 1 extra box of unresisted Matrix damage when attacked"
        },
        {
          "program": "Armor",
          "effect": "+2 dice pool modifier to resist Matrix damage"
        },
        {
          "program": "Biofeedback Filter",
          "effect": "+2 dice pool modifier to resist biofeedback damage"
        },
        {
          "program": "Guard",
          "effect": "Reduce extra damage from marks by 1 DV per mark"
        },
        {
          "program": "Shell",
          "effect": "+1 dice pool modifier against Matrix and biofeedback damage, cumulative with other programs"
        },
        {
          "program": "Sneak",
          "effect": "+2 dice pool modifier to defend against Trace User actions"
        },
        {
          "program": "Wrapper",
          "effect": "Allows defying Matrix iconography rules"
        }
      ]
    },
    "control-override-priority": {
