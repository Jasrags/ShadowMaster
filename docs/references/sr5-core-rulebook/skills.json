          "value": "+1"
        },
        {
          "section": "Dice Pool Modifier — Surface",
          "situation": "Broken (tree, loose stone wall)",
          "value": "+0"
        },
        {
          "section": "Dice Pool Modifier — Surface",
          "situation": "Flat (brick wall, side of old building)",
          "value": "-3"
        },
        {
          "section": "Dice Pool Modifier — Surface",
          "situation": "Sheer (metal wall, seamless stone)",
          "value": "-5"
