    "climbing-table": {
      "source": "SR5 Core Rulebook, p.134",
      "description": "Movement distance (round up) and dice pool modifiers for climbing by situation and surface type",
      "columns": ["situation", "movementDistanceOrModifier"],
      "rows": [
        {
          "section": "Movement Distance (round up)",
          "situation": "Assisted climbing down (rappelling)",
          "value": "20 meters + 1 meter per hit"
        },
        {
          "section": "Movement Distance (round up)",
          "situation": "Assisted climbing upward",
          "value": "1 meter per hit"
        },
        {
          "section": "Movement Distance (round up)",
          "situation": "Assisted climbing horizontally",
          "value": "1 meter per 2 hits"
        },
        {
          "section": "Movement Distance (round up)",
          "situation": "Assisted climbing upside down (on a ceiling or overhang)",
          "value": "1 meter per 3 hits"
        },
        {
          "section": "Movement Distance (round up)",
          "situation": "Unassisted climbing upward",
          "value": "1 meter per 2 hits"
        },
        {
          "section": "Movement Distance (round up)",
