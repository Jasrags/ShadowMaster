{
  "tables": {
    "skill-ratings": {
      "source": "SR5 Core Rulebook, p.129",
      "description": "Descriptive labels for skill rating values 0 through 13",
      "columns": ["rating", "label", "notes"],
      "rows": [
        {
          "rating": "No Rating",
          "label": "Unaware",
          "notes": "Special level of ignorance; requires Incompetent quality or defined history deficiency. Cannot default. Skill never occurs to character as a solution."
        },
        {
          "rating": 0,
          "label": "Untrained",
          "notes": "Default knowledge from society and Matrix interaction. Can attempt defaultable skills at -1 die."
        },
        {
          "rating": 1,
          "label": "Beginner",
          "notes": "A little training; knows how it works but not always why."
        },
        { "rating": 2, "label": "Novice", "notes": "Hobbyist, not an enthusiast." },
        {
          "rating": 3,
          "label": "Competent",
          "notes": "Skilled at basic operations; struggles with complex operations and tricks."
        },
        {
          "rating": 4,
          "label": "Proficient",
          "notes": "Comfortable; performs well under normal pressure. Professional level for most jobs."
        },
        {
          "rating": 5,
          "label": "Skilled",
          "notes": "Handles unfamiliar situations; gets creative."
        },
        {
          "rating": 6,
          "label": "Professional",
          "notes": "Could sell skills on the open market. Maximum skill level for starting player characters."
        },
        {
          "rating": 7,
          "label": "Veteran",
          "notes": "Has seen what the skill can and cannot do. Others ask for advice."
        },
        {
          "rating": 8,
          "label": "Expert",
          "notes": "Highly sought-after talent. Corporations recruit actively."
        },
        { "rating": 9, "label": "Exceptional", "notes": "Name is synonymous with the skill." },
        {
          "rating": 10,
          "label": "Elite",
          "notes": "Famous even among the very best in the field."
        },
        {
          "rating": 11,
          "label": "Legendary",
          "notes": "A paragon; techniques named after the character."
        },
        {
          "rating": 12,
          "label": "Apex",
          "notes": "Top 0.00001% of all practitioners in known history."
        },
        {
          "rating": 13,
          "label": "Apex",
          "notes": "Pinnacle achievable only with the Aptitude quality (p. 72)."
        }
      ]
    },
