    "final-calculations": {
      "source": "SR5 Core Rulebook, p.101",
      "description": "Formulas for all derived statistics calculated in Step 8",
      "columns": ["mechanic", "formula", "augmentation_bonuses"],
      "rows": [
        {
          "mechanic": "Initiative",
          "formula": "(Intuition + Reaction) + 1D6",
          "augmentation_bonuses": "Add appropriate attribute and Initiative Dice bonuses"
        },
        {
          "mechanic": "Astral Initiative",
          "formula": "(Intuition x 2) + 2D6",
          "augmentation_bonuses": null
        },
        {
          "mechanic": "Matrix AR Initiative",
          "formula": "(Intuition + Reaction) + 1D6",
          "augmentation_bonuses": null
        },
        {
          "mechanic": "Matrix VR Initiative (Cold Sim)",
          "formula": "(Data Processing + Intuition) + 3D6",
          "augmentation_bonuses": null
        },
        {
          "mechanic": "Matrix VR Initiative (Hot Sim)",
          "formula": "(Data Processing + Intuition) + 4D6",
          "augmentation_bonuses": null
        },
        {
          "mechanic": "Mental Limit",
          "formula": "[(Logic x 2) + Intuition + Willpower] / 3 (round up)",
          "augmentation_bonuses": null
        },
        {
          "mechanic": "Physical Limit",
          "formula": "[(Strength x 2) + Body + Reaction] / 3 (round up)",
          "augmentation_bonuses": null
        },
        {
          "mechanic": "Social Limit",
          "formula": "[(Charisma x 2) + Willpower + Essence] / 3 (round up)",
          "augmentation_bonuses": "Round Essence UP before calculating"
        },
        {
          "mechanic": "Physical Condition Monitor",
          "formula": "[Body / 2] + 8 (round up)",
          "augmentation_bonuses": "Add bonuses to Body before calculating"
        },
        {
