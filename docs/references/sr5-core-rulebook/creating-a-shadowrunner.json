          "factor": "Uncommon",
          "value": 2,
          "description": "Rare substance/condition. Examples: silver, gold, antibiotics, grass"
        },
        {
          "factor": "Common",
          "value": 7,
          "description": "Prevalent substance/condition. Examples: sunlight, seafood, bees, pollen, pollutants, Wi-Fi, soy, wheat"
        },
        { "factor": "Mild", "value": 3, "description": "-2 dice pool modifier to Physical Tests" },
        {
          "factor": "Moderate",
          "value": 8,
          "description": "-4 dice pool modifier to all Physical Tests"
        },
        {
          "factor": "Severe",
          "value": 13,
          "description": "-4 dice pool modifier to all tests, +1 box Physical Damage (unresisted) per minute exposed"
        },
        {
          "factor": "Extreme",
          "value": 18,
          "description": "-6 dice pool modifier to all tests, +1 box Physical Damage (unresisted) per 30 seconds exposed. Anaphylactic shock"
        }
