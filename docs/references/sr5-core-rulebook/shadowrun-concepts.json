        { "task": "Quick", "timeInterval": "1 minute" },
        { "task": "Short", "timeInterval": "10 minutes" },
        { "task": "Average", "timeInterval": "30 minutes" },
        { "task": "Long", "timeInterval": "1 hour" },
        { "task": "Consuming", "timeInterval": "1 day" },
        { "task": "Exhaustive", "timeInterval": "1 week" },
        { "task": "Mammoth", "timeInterval": "1 month" }
